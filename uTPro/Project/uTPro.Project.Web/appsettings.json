{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Umbraco": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "UmbracoFile",
        "Args": {
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 310
        }
      }
    ]
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Server=localhost;Port=5432;Database=uTPro;User Id=postgres;Password=postgres;",
    "umbracoDbDSN_ProviderName": "Npgsql2"
  },
  "uTPro": {
    "Hosting": {
      "TempPath": ""
    },
    "ForwardedHeaders": {
      "Enabled": false,
      "ForwardLimit": 1,
      "KnownProxies": [],
      "KnownNetworks": [],
      "TrustAllProxies": false
    },
    "Backoffice": {
      "Enabled": true,
      "Domain": "bo.utpro.local"
    },
    "RememberLanguage": {
      "Enabled": true,
      "ListExludeRequestLanguage": {
        "Enabled": true,
        "Paths": [
          "api"
        ]
      }
    },
    "Feature": {
      "FileManager": {
        "MaxUploadSizeMB": 50,
        "AllowedUploadExtensions": [],
        "BlockedUploadExtensions": [
          ".exe",
          ".dll",
          ".bat",
          ".cmd"
        ]
      },
      "Form": {
        "RateLimit": {
          "Enabled": true,
          "PermitLimit": 5,
          "WindowSeconds": 60
        }
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Smtp": {
          "From": "no.reply@t4vn.com",
          "Host": "smtp.gmail.com",
          "Port": 587,
          "Username": "no.reply@t4vn.com",
          "Password": "password",
          "SecureSocketOptions": "Auto",
          "DeliveryMethod": "Network"
        },
        "Id": "906dea88-5bb7-479d-b734-f6a5a1ab11df",
        "UseHttps": true,
        "SanitizeTinyMce": true,
        "UmbracoMediaPath": "~/uploads",
        "MainDomLock": "FileSystemMainDomLock"
      },
      "Hosting": {
        "Debug": false,
        "LocalTempStorageLocation": "EnvironmentTemp"
      },
      "Examine": {
        "LuceneDirectoryFactory": "TempFileSystemDirectoryFactory"
      },
      "ReservedPaths": "~/app_plugins/,~/install/,~/mini-profiler-resources/,~/umbraco/,~/error/",
      "Content": {
        "Notifications": {
          "Email": null
        },
        "LoginBackgroundImage": "../assets/img/bkg-login.jpg",
        "LoginLogoImage": "../assets/img/logo.svg",
        "LoginLogoImageAlternative": "../assets/img/logo.svg",
        "BackOfficeLogo": "../assets/img/logo.svg",
        "HideBackOfficeLogo": true,
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true,
          "KeepAllVersionsNewerThanDays": 7,
          "KeepLatestVersionPerDayForDays": 90
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Runtime": {
        "Mode": "Production"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "uSync": {
    "Settings": {
      "ImportOnFirstBoot": true,
      "FirstBootGroup": "All"
    }
  }
}