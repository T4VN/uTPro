@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockGridItem<UTpro__ContactForm>>
@{
}

@if (Context.Request.IsBlockPreviewRequest())
{
    <link rel="stylesheet" href="~/css/@CurrentSite.GetItem().Root.Name/Components/ContactForm.css" />
}
else
{
    @using (Html.SetSection(Model.GetType().ToString(), HtmlSectionBlockExtensions.Position.BodyBottom))
    {
        <link rel="stylesheet" href="~/css/@CurrentSite.GetItem().Root.Name/Components/ContactForm.css" />
    }
}
<section class="container contactform">
    <div class="row">
        @if (!string.IsNullOrEmpty(Model.Content.ContactForm))
        {
            <div class="col-6 col-12-medium">
                <section>
                    @await Component.InvokeAsync("uTProSimpleForm", new { alias = Model.Content.ContactForm })
                </section>

            </div>
        }
        <div class="col-6 col-12-medium">

            <!-- Contact -->
            <section class="feature-list small">
                <div class="row">
                    <div class="col-6 col-12-small">
                        <section>
                            <h3 class="icon solid fa-home">Address</h3>
                            <div class="paragraph p0">
                                @Model.Content.Address
                            </div>
                        </section>
                    </div>
                    <div class="col-6 col-12-small">
                        <section>
                            <h3 class="icon solid fa-comment">Social</h3>
                            <div class="paragraph p0">
                                @if (Model.Content.Social != null)
                                {
                                    foreach (var item in Model.Content.Social.ToList())
                                    {
                                        <p>
                                            <a target="@item.Target" href="@item.Url">@item.Name</a>
                                        </p>
                                    }
                                }
                            </div>
                        </section>
                    </div>
                    <div class="col-6 col-12-small">
                        <section>
                            <h3 class="icon solid fa-envelope">Email</h3>
                            @if (Model.Content.Email != null)
                            {
                                foreach (var item in Model.Content.Email.ToList())
                                {
                                    <p>
                                        <a target="@item.Target" href="@item.Url">@item.Name</a>
                                    </p>
                                }
                            }
                        </section>
                    </div>
                    <div class="col-6 col-12-small">
                        <section>
                            <h3 class="icon solid fa-phone">Phone</h3>
                            @if (Model.Content.Phone != null)
                            {
                                foreach (var item in Model.Content.Phone.ToList())
                                {
                                    <p>
                                        <a target="@item.Target" href="@item.Url">@item.Name</a>
                                    </p>
                                }
                            }
                        </section>
                    </div>
                </div>
            </section>

        </div>
    </div>
</section>