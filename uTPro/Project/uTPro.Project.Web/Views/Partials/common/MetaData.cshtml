@using System.Net
@inject Umbraco.Cms.Core.Services.IDomainService _domainService
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var folderSettings = CurrentSite.GetItem().FolderSettings;
    var folderSite = CurrentSite.GetItem().FolderSite;
    if (folderSettings == null || folderSite == null || Model == null)
    {
        return;
    }

    var seo = Model.Value<SeoVisualizer.SeoValues>(nameof(GlobalPageHeadMetaSetting.HeadTitleAndDescription));
    string url = $"{Context.Request.Scheme}://{Context.Request.Host}";
    string canonical = Model.Url(mode: UrlMode.Absolute);
    string sitemap = $"{url}/sitemap.xml";
    var title = GetTitle();
    var description = GetDescription();
    var thumbnail = GetThumbnail();
    var ogImage = GetOgImage();

    IHtmlContent GetTitle()
    {
        string? value = seo?.Title;
        if (string.IsNullOrEmpty(value))
        {
            value = Model.Name();
        }
        if (!string.IsNullOrEmpty(folderSettings.Value<string>(nameof(folderSettings.SiteTitleSuffix))))
        {
            value = folderSettings.Value<string>(nameof(folderSettings.SiteTitleSuffix))?
            .Replace("<titlePage>", value)
            .Replace("<titleSiteName>", folderSite.SiteName?.Title, StringComparison.OrdinalIgnoreCase);
        }
        return Html.Raw(value ?? string.Empty);
    }

    IHtmlContent GetDescription()
    {
        string? value = seo?.Description;
        if (string.IsNullOrEmpty(value))
        {
            value = folderSite.SiteName?.Description;
        }
        return Html.Raw(value ?? string.Empty);
    }

    IHtmlContent GetThumbnail()
    {
        string value = Model.ValueToMediaMobile(nameof(GlobalPageHeadMetaSetting.HeadSocialShareImage));
        if (string.IsNullOrEmpty(value))
        {
            value = folderSite.ValueToMediaMobile(nameof(GlobalSiteSettings.SiteSettingsLogo));
        }
        return Html.Raw(value);
    }

    /// <summary>
    /// OG/Twitter image should be 1200x630 for optimal social sharing.
    /// Uses desktop crop (wider) instead of mobile crop.
    /// </summary>
    string GetOgImage()
    {
        string value = !string.IsNullOrEmpty(Model.ValueToMediaDesktop(nameof(GlobalPageHeadSocialMetaSetting.OgImage)))
            ? Model.ValueToMediaDesktop(nameof(GlobalPageHeadSocialMetaSetting.OgImage))
            : Model.ValueToMediaDesktop(nameof(GlobalPageHeadMetaSetting.HeadSocialShareImage));
        if (string.IsNullOrEmpty(value))
        {
            value = folderSite.ValueToMediaDesktop(nameof(GlobalSiteSettings.SiteSettingsLogo));
        }
        // Ensure absolute URL
        if (!string.IsNullOrEmpty(value) && !value.StartsWith("http"))
        {
            value = url + value;
        }
        return value;
    }

    IHtmlContent GetSocialFB()
    {
        List<string> value = new List<string>();
        string ogType = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgType)))
            ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgType))
            : "website";
        value.Add($"<meta property=\"og:type\" content=\"{WebUtility.HtmlEncode(ogType)}\"/>");

        var ogTitle = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgTitle)))
                        ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgTitle))
                        : title.ToHtmlString();
        value.Add($"<meta property=\"og:title\" content=\"{WebUtility.HtmlEncode(ogTitle)}\"/>");

        var ogDesc = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgDescription)))
                        ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgDescription))
                        : description.ToHtmlString();
        value.Add($"<meta property=\"og:description\" content=\"{WebUtility.HtmlEncode(ogDesc)}\"/>");

        value.Add($"<meta property=\"og:image\" content=\"{WebUtility.HtmlEncode(ogImage)}\"/>");
        value.Add($"<meta property=\"og:image:width\" content=\"1200\"/>");
        value.Add($"<meta property=\"og:image:height\" content=\"630\"/>");

        if (!string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.FacebookAppId))))
        {
            value.Add($"<meta property=\"fb:app_id\" content=\"{WebUtility.HtmlEncode(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.FacebookAppId)))}\"/>");
        }
        value.Add($"<meta property=\"og:url\" content=\"{WebUtility.HtmlEncode(canonical)}\"/>");
        value.Add($"<meta property=\"og:locale\" content=\"{CurrentSite.CurrentCulture.Name}\"/>");
        value.Add($"<meta property=\"og:site_name\" content=\"{WebUtility.HtmlEncode(folderSite.SiteName?.Title ?? "")}\"/>");
        return Html.Raw(string.Join(Environment.NewLine, value));
    }

    IHtmlContent GetSocialTwitter()
    {
        List<string> value = new List<string>();
        string cardType = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterCardType)))
            ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterCardType))
            : "summary_large_image";
        value.Add($"<meta name=\"twitter:card\" content=\"{WebUtility.HtmlEncode(cardType)}\"/>");

        var twTitle = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgTitle)))
                        ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgTitle))
                        : title.ToHtmlString();
        value.Add($"<meta name=\"twitter:title\" content=\"{WebUtility.HtmlEncode(twTitle)}\"/>");

        var twDesc = !string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgDescription)))
                        ? Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.OgDescription))
                        : description.ToHtmlString();
        value.Add($"<meta name=\"twitter:description\" content=\"{WebUtility.HtmlEncode(twDesc)}\"/>");

        value.Add($"<meta name=\"twitter:image\" content=\"{WebUtility.HtmlEncode(ogImage)}\"/>");

        if (!string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterSite))))
        {
            value.Add($"<meta name=\"twitter:site\" content=\"{WebUtility.HtmlEncode(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterSite)))}\"/>");
        }

        if (!string.IsNullOrEmpty(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterImageAlt))))
        {
            value.Add($"<meta name=\"twitter:image:alt\" content=\"{WebUtility.HtmlEncode(Model.ValueToString(nameof(GlobalPageHeadSocialMetaSetting.TwitterImageAlt)))}\"/>");
        }
        return Html.Raw(string.Join(Environment.NewLine, value));
    }

    IHtmlContent GetAlternateHreflang()
    {
        List<string> value = new List<string>();
        string formatTag = "<link rel=\"alternate\" hreflang=\"{0}\" href=\"{1}\" />";
        var lstDomain = CurrentSite.GetDomains(true);
        if (lstDomain.Count > 1)
        {
            var domainDefault = lstDomain.FirstOrDefault(x => x.Name.EndsWith("/"));
            // x-default: use default culture URL or first domain
            string xDefaultUrl = Model.Url(mode: UrlMode.Absolute, culture: domainDefault?.Culture ?? lstDomain[0].Culture);
            value.Add(string.Format(formatTag, "x-default", xDefaultUrl));

            foreach (var item in lstDomain)
            {
                var itemUrl = Model.Url(mode: UrlMode.Absolute, culture: item.Culture);
                value.Add(string.Format(formatTag, item.Culture?.ToLower(), itemUrl));
            }
        }

        return Html.Raw(string.Join(Environment.NewLine, value));
    }

    /// <summary>
    /// Build breadcrumb JSON-LD from ancestors
    /// </summary>
    IHtmlContent GetBreadcrumbJsonLd()
    {
        var ancestors = Model.AncestorsOrSelf().Reverse().ToList();
        if (ancestors.Count <= 1) return Html.Raw(string.Empty);

        var items = new List<string>();
        int position = 1;
        foreach (var item in ancestors)
        {
            var itemUrl = item.Url(mode: UrlMode.Absolute);
            if (string.IsNullOrWhiteSpace(itemUrl))
            {
                continue;
            }

            var itemName = WebUtility.HtmlEncode(item.Name());
            items.Add($@"{{""@type"":""ListItem"",""position"":{position},""name"":""{itemName}"",""item"":""{itemUrl}""}}");
            position++;
        }

        if (items.Count == 0) return Html.Raw(string.Empty);
        var json = $@"{{""@context"":""https://schema.org"",""@type"":""BreadcrumbList"",""itemListElement"":[{string.Join(",", items)}]}}";
        return Html.Raw($"<script type=\"application/ld+json\">{json}</script>");
    }
}

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

@if (Model.Value<bool>(nameof(GlobalPageSitemapSetting.SitemapStopInternalLinksBeingFollowed)))
{
    <meta name="robots" content="noindex, nofollow, noarchive">
}
else
{
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
}

<title>@title</title>
<meta name="title" content="@title" />
@if (!string.IsNullOrEmpty(description.ToHtmlString()))
{
    <meta name="description" content="@description" />
}
<link rel="canonical" href="@canonical" />
<link rel="sitemap" href="@sitemap" />
<link rel="shortcut icon" href="@(folderSite.SiteFavicon != null ? folderSite.SiteFavicon.Url() : "/favicon.ico")" />
@GetSocialFB()
@GetSocialTwitter()
@(GetAlternateHreflang())

@* JSON-LD: WebSite + SearchAction *@
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "WebSite",
    "name": "@WebUtility.HtmlEncode(folderSite.SiteName?.Title ?? "")",
    "url": "@url",
    @if (!string.IsNullOrEmpty(description.ToHtmlString()))
    {
        @:"description": "@WebUtility.HtmlEncode(description.ToHtmlString())",
    }
    "inLanguage": "@CurrentSite.CurrentCulture.Name"
}
</script>

@* JSON-LD: Organization *@
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "Organization",
    "name": "@WebUtility.HtmlEncode(folderSite.SiteName?.Title ?? "")",
    "url": "@url",
    "logo": "@(folderSite.SiteLogo != null ? url + folderSite.SiteLogo.Url() : url + "/assets/img/logo.svg")"
}
</script>

@* JSON-LD: BreadcrumbList *@
@GetBreadcrumbJsonLd()
