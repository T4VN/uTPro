        {
          "alias": "title",
          "culture": "en-US",
          "editorAlias": null,
          "segment": null,
          "value": "Introduction"
        }
      ]
    },
    {
      "contentTypeKey": "7933a097-e795-4929-9746-d802b4ed8595",
      "key": "3c965ae0-8d59-4016-a50c-66711df491cb",
      "values": [
        {
          "alias": "thumbnail",
          "culture": "en-US",
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "key": "add69051-7716-42e8-a8c6-d1e2d9aac367",
              "mediaKey": "37745161-cecc-4394-a93b-8f64c5cc6ea3",
              "mediaTypeAlias": "Image",
              "crops": [],
              "focalPoint": null
            }
          ]
        },
        {
          "alias": "description",
          "culture": "en-US",
          "editorAlias": null,
          "segment": null,
          "value": "For developers, by developers"
        },
        {
          "alias": "title",
          "culture": "en-US",
          "editorAlias": null,
          "segment": null,
          "value": "uTPro \u2013 Umbraco Turbo Pro"
        },
        {
          "alias": "content",
          "culture": "en-US",
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "be80a795-b398-4baa-860a-ee68b7124f11",
                "key": "d9baf74a-cb1a-4643-ade2-c5878534a6f3",
                "values": [
                  {
                    "alias": "richtext",
                    "culture": "en-US",
                    "editorAlias": null,
                    "segment": null,
                    "value": {
                      "blocks": {
                        "contentData": [],
                        "settingsData": [],
                        "expose": [],
                        "layout": {}
                      },
                      "markup": "\u003Cp\u003E\u003Cstrong\u003EuTPro\u003C/strong\u003E is a powerful \u003Cstrong\u003EStarter Kit Template\u003C/strong\u003E designed to \u003Cstrong\u003Eaccelerate the speed of website development on the Umbraco platform.\u003C/strong\u003E\u003C/p\u003E\u003Cp\u003EIt helps developers build \u003Cstrong\u003Eenterprise-grade\u003C/strong\u003E websites faster, more reliably, and with a professional structure right from day one.\u003C/p\u003E\u003Cp\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EuTPro is developed based on the core foundation of \u003C/span\u003E\u003Cstrong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EUmbraco. \u003C/span\u003E\u003C/strong\u003E\u003Cspan style=\u0022white-space: pre-wrap;\u0022\u003EThanks to this foundation, we ensure the product always adheres to the core principles of Umbraco \u2014 a .NET-based content management system (CMS), renowned for its flexibility, user-friendly experience, strong community ecosystem, and outstanding long-term value.\u003C/span\u003E\u003C/p\u003E\u003Cp\u003EOur key advantages include:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003ETrue flexibility\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EHigh ROI (Cost optimization)\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003ERapid deployment\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003EEnterprise-ready\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EOverall, Umbraco is particularly suitable for:\u003C/p\u003E\u003Cul\u003E\u003Cli\u003E\u003Cp\u003EBusinesses looking for flexible, scalable digital solutions with low operating costs and fast cloud development capabilities\u003C/p\u003E\u003C/li\u003E\u003Cli\u003E\u003Cp\u003E.NET tech agencies needing efficient deployment, high customizability, and a modern CMS to meet the diverse needs of their clients\u003C/p\u003E\u003C/li\u003E\u003C/ul\u003E\u003Cp\u003EuTPro is \u003Cstrong\u003Ecompletely free and open-source\u003C/strong\u003E, giving developers the freedom to \u003Cstrong\u003Ecustomize, extend, and innovate without limits...\u003C/strong\u003E\u003C/p\u003E"
                    }
                  }
                ]
              }
            ],
            "settingsData": [],
            "expose": [
              {
                "contentKey": "d9baf74a-cb1a-4643-ade2-c5878534a6f3",
