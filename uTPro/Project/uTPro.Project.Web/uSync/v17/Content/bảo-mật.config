      <Value Culture="en-US"><![CDATA[{
  "contentData": [
    {
      "contentTypeKey": "d8c525b6-c39b-47f9-9e7e-6cc60eae7a17",
      "key": "4dbbd831-228b-4130-ac23-ab693bee38ec",
      "values": [
        {
          "alias": "backgroundColor",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "label": "",
            "value": "#fff"
          }
        },
        {
          "alias": "textColor",
          "culture": null,
