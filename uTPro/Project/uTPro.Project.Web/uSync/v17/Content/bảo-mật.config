                }
              ]
            }
          }
        },
        {
          "alias": "title",
          "culture": "vi-VN",
          "editorAlias": null,
          "segment": null,
          "value": "B\u00E1o c\u00E1o l\u1ED7 h\u1ED5ng b\u1EA3o m\u1EADt"
        },
        {
          "alias": "description",
          "culture": "vi-VN",
          "editorAlias": null,
          "segment": null,
          "value": "C\u1EA3m \u01A1n b\u1EA1n \u0111\u00E3 gi\u00FAp ch\u00FAng t\u00F4i n\u00E2ng cao t\u00EDnh b\u1EA3o m\u1EADt v\u00E0 \u0111\u1ED9 tin c\u1EADy c\u1EE7a uTPro."
        }
      ]
    }
  ],
