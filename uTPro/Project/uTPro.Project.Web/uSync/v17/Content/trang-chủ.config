                "values": [
                  {
                    "alias": "description",
                    "culture": "vi-VN",
                    "editorAlias": null,
                    "segment": null,
                    "value": "M\u1ED9t tr\u1EA3i nghi\u1EC7m xu\u1EA5t s\u1EAFc v\u1EDBi m\u00E3 ngu\u1ED3n ch\u1EC9n chu, b\u1ED1 c\u1EE5c tuy\u1EC7t v\u1EDDi, giao di\u1EC7n s\u1EA1ch s\u1EBD v\u00E0 t\u00E0i li\u1EC7u h\u01B0\u1EDBng d\u1EABn to\u00E0n di\u1EC7n."
