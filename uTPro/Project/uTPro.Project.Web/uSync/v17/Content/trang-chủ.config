                    "culture": "vi-VN",
                    "editorAlias": null,
                    "segment": null,
                    "value": "Orifarm"
                  },
                  {
                    "alias": "link",
                    "culture": "vi-VN",
                    "editorAlias": null,
                    "segment": null,
                    "value": [
                      {
                        "name": "www.orifarm.com",
