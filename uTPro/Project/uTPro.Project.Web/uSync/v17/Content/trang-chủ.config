          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003EuTPro l\u00E0 m\u1ED9t Starter Kit Template m\u1EA1nh m\u1EBD \u0111\u01B0\u1EE3c thi\u1EBFt k\u1EBF \u0111\u1EC3 \u0111\u1EA9y nhanh t\u1ED1c \u0111\u1ED9 ph\u00E1t tri\u1EC3n website tr\u00EAn n\u1EC1n t\u1EA3ng Umbraco.\u003C/p\u003E\u003Cp\u003EN\u00F3 gi\u00FAp c\u00E1c l\u1EADp tr\u00ECnh vi\u00EAn x\u00E2y d\u1EF1ng c\u00E1c trang web c\u1EA5p doanh nghi\u1EC7p nhanh h\u01A1n, \u0111\u00E1ng tin c\u1EADy h\u01A1n v\u00E0 c\u00F3 c\u1EA5u tr\u00FAc chuy\u00EAn nghi\u1EC7p ngay t\u1EEB ng\u00E0y \u0111\u1EA7u ti\u00EAn.\u003C/p\u003E"
          }
        },
        {
          "alias": "callToAction",
          "culture": "vi-VN",
          "editorAlias": null,
          "segment": null,
          "value": [
            {
              "name": "Tr\u1EA3i nghi\u1EC7m MI\u1EC4N PH\u00CD",
              "target": "_blank",
              "unique": null,
              "type": null,
              "udi": null,
              "url": "https://github.com/T4VN/uTPro/releases",
