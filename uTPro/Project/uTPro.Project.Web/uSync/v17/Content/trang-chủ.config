          "segment": null,
          "value": "Umbraco Turbo Pro - uTPro"
        },
        {
          "alias": "highlight",
          "culture": "vi-VN",
          "editorAlias": null,
          "segment": null,
          "value": {
            "contentData": [
              {
                "contentTypeKey": "387b74d5-d355-43c3-b89c-999f3a121f71",
                "key": "c1f15c3a-d1f9-4053-9bf6-59f43363792d",
                "values": [
                  {
                    "alias": "description",
                    "culture": "vi-VN",
                    "editorAlias": null,
                    "segment": null,
                    "value": "M\u1ED9t tr\u1EA3i nghi\u1EC7m ho\u00E0n h\u1EA3o v\u1EC1 m\u1ECDi m\u1EB7t! M\u00E3 ngu\u1ED3n kh\u00F4ng ch\u1EC9 s\u1EA1ch m\u00E0 c\u00F2n c\u1EF1c k\u1EF3 ch\u1EC9n chu, b\u1ED1 c\u1EE5c thi\u1EBFt k\u1EBF v\u00F4 c\u00F9ng tuy\u1EC7t v\u1EDDi, giao di\u1EC7n tinh t\u1EBF, tr\u1EF1c quan, c\u00F2n t\u00E0i li\u1EC7u h\u01B0\u1EDBng d\u1EABn th\u00EC r\u1EA5t chi ti\u1EBFt v\u00E0 \u0111\u01B0\u1EE3c t\u1ED5 ch\u1EE9c m\u1ED9t c\u00E1ch khoa h\u1ECDc."
                  },
