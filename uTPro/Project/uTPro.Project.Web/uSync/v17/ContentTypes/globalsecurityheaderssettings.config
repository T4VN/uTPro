<?xml version="1.0" encoding="utf-8"?>
<ContentType Key="13485830-1c4b-489e-8542-313fa08f0e2e" Alias="globalSecurityHeadersSettings" Level="3">
  <Info>
    <Name>Global - Security Headers Settings</Name>
    <Icon>icon-document-settings color-yellow</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description></Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Nothing</Variations>
    <IsElement>false</IsElement>
    <HistoryCleanup>
      <PreventCleanup>False</PreventCleanup>
      <KeepAllVersionsNewerThanDays></KeepAllVersionsNewerThanDays>
      <KeepLatestVersionPerDayForDays></KeepLatestVersionPerDayForDays>
    </HistoryCleanup>
    <Folder>Global+-+Common/Global+-+Common+%7c+Inherited+Settings</Folder>
    <Compositions />
    <DefaultTemplate></DefaultTemplate>
    <AllowedTemplates />
  </Info>
  <Structure />
  <GenericProperties>
    <GenericProperty>
      <Key>f629dc56-ad69-4a94-a535-c5cc593f589c</Key>
      <Name>Content-Security-Policy (CSP)</Name>
      <Alias>contentSecurityPolicyCsp</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Defines which sources of content are allowed to load (defends against XSS/injection). Very powerful but easy to break the site — test with Report-Only first. If set without frame-ancestors, it is appended automatically so preview keeps working.
Blank: the system auto-generates frame-ancestors to allow backoffice preview.]]></Description>
      <SortOrder>5</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>b33f1f37-ca49-4eca-bb83-199503d39168</Key>
      <Name>Content-Security-Policy-Report-Only</Name>
      <Alias>contentSecurityPolicyReportOnly</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[On = the CSP only reports violations without blocking (safe for testing). 
Off = the CSP is enforced (actually blocks). 
]]></Description>
      <SortOrder>6</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>b8e89076-bf62-44fc-b04b-2f13b08ebd41</Key>
      <Name>Enabled</Name>
      <Alias>enabled</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Master switch for this site's security headers. When off, no security headers are sent at all. Must be on for the settings below to take effect.]]></Description>
      <SortOrder>0</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>966216dd-6b46-403d-a623-84eb21dc5f51</Key>
      <Name>Hsts Enabled</Name>
      <Alias>hstsEnabled</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Forces browsers to always use HTTPS for this domain. Sent only over HTTPS connections. Use with care: once sent with a long duration it is hard to undo.]]></Description>
      <SortOrder>0</SortOrder>
      <Tab Alias="securityHeaders/hTTPStrictTransportSecurity(HSTS)">HTTP Strict Transport Security (HSTS)</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>be8f46b2-eee4-47b3-8132-dae116fdc1b9</Key>
      <Name>Hsts Include Sub Domains</Name>
      <Alias>hstsIncludeSubDomains</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Applies HSTS to all subdomains. 
Enable only when every subdomain serves HTTPS.]]></Description>
      <SortOrder>2</SortOrder>
      <Tab Alias="securityHeaders/hTTPStrictTransportSecurity(HSTS)">HTTP Strict Transport Security (HSTS)</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>ce33741b-fea9-4985-a3e1-97b376af0f69</Key>
      <Name>Hsts Max Age Seconds</Name>
      <Alias>hstsMaxAgeSeconds</Alias>
      <Definition>2e6d3631-066e-44b8-aec4-96f09099b2b5</Definition>
      <Type>Umbraco.Integer</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[How long (in seconds) the browser remembers to use HTTPS only. 
Blank or 0 = default 31536000 (1 year).]]></Description>
      <SortOrder>1</SortOrder>
      <Tab Alias="securityHeaders/hTTPStrictTransportSecurity(HSTS)">HTTP Strict Transport Security (HSTS)</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>6946dfbe-b468-4ca7-bcb0-731027ff95fc</Key>
      <Name>Hsts Preload</Name>
      <Alias>hstsPreload</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Requests inclusion in the browsers' HSTS preload list. 
Enable only if you understand the implications (requires max-age ≥ 1 year + includeSubDomains, and is hard to remove from the list).]]></Description>
      <SortOrder>3</SortOrder>
      <Tab Alias="securityHeaders/hTTPStrictTransportSecurity(HSTS)">HTTP Strict Transport Security (HSTS)</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>4da0491a-3d76-4ee3-9646-335e5f28c5b2</Key>
      <Name>Permissions-Policy</Name>
      <Alias>permissionsPolicy</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Restricts access to browser features (camera, microphone, geolocation, etc.).
Example: camera=(), microphone=(), geolocation=().]]></Description>
      <SortOrder>4</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>9f254986-65c8-4a60-9439-e4a9714f16c2</Key>
      <Name>Referrer-Policy</Name>
      <Alias>referrerPolicy</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Controls how much referrer information is sent when navigating away.
Recommended: strict-origin-when-cross-origin.]]></Description>
      <SortOrder>3</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>44c6d419-59ed-45b0-b2d2-4f5de5dc597d</Key>
      <Name>X-Content-Type-Options</Name>
      <Alias>xContentTypeOptions</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Stops browsers from MIME-sniffing (guessing a file's type). Leave blank to use the default nosniff (recommended). 
Only nosniff or blank is meaningful.]]></Description>
      <SortOrder>1</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>7c7836ef-1608-463c-ac58-fbb8c0082bd7</Key>
      <Name>X-Frame-Options</Name>
      <Alias>xFrameOptions</Alias>
      <Definition>c6bac0dd-4ab9-45b1-8e30-e4b619ee5da3</Definition>
      <Type>Umbraco.TextArea</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Prevents the site from being embedded in an iframe (clickjacking). 
Blank = SAMEORIGIN. 
Note: this applies only when no CSP is set and no backoffice host is configured; when a backoffice host exists the system uses CSP frame-ancestors instead and ignores this field. 
Valid values: SAMEORIGIN or DENY.]]></Description>
      <SortOrder>2</SortOrder>
      <Tab Alias="securityHeaders">Security Headers</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
  </GenericProperties>
  <Tabs>
    <Tab>
      <Key>d60463cc-7faf-4c70-9da9-28cfd5ae695d</Key>
      <Caption>HTTP Strict Transport Security (HSTS)</Caption>
      <Alias>securityHeaders/hTTPStrictTransportSecurity(HSTS)</Alias>
      <Type>Group</Type>
      <SortOrder>0</SortOrder>
    </Tab>
    <Tab>
      <Key>e47ee317-12ba-4dd9-8852-db135d582665</Key>
      <Caption>Security Headers</Caption>
      <Alias>securityHeaders</Alias>
      <Type>Tab</Type>
      <SortOrder>0</SortOrder>
    </Tab>
  </Tabs>
</ContentType>