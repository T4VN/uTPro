      <Alias>defaultLayout</Alias>
      <Definition>d5f1a7c2-3b4e-4a6d-9c81-2e5f7a9b1c3d</Definition>
      <Type>Umbraco.RadioButtonList</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Layout applied to all child pages that don't set their own. Empty = full width.]]></Description>
      <SortOrder>-1</SortOrder>
      <Tab Alias="layout">Layout</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>b1f2a3c4-d5e6-47f8-9a0b-1c2d3e4f5a6b</Key>
      <Name>Show In URL</Name>
      <Alias>showInUrl</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[When ON, this folder's segment is included in the URL of its child pages, and the folder itself redirects to its parent page. When OFF (default), the folder is transparent and child URLs skip it]]></Description>
      <SortOrder>-3</SortOrder>
      <Tab Alias="layout">Layout</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>e2b3c4d5-e6f7-4081-9293-a4b5c6d7e8f0</Key>
      <Name>Sidebar Component</Name>
