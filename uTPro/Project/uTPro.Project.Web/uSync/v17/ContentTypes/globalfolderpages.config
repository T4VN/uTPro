  <GenericProperties>
    <GenericProperty>
      <Key>dbe5f607-8293-44a5-96b7-283940516274</Key>
      <Name>Append To Inherited</Name>
      <Alias>appendToInherited</Alias>
      <Definition>92897bc6-a5f3-4ffe-ae27-f2e7e33dda49</Definition>
      <Type>Umbraco.TrueFalse</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[When ON, the Top/Sidebar/Bottom set here are ADDED to the ones inherited from outer pages (e.g. the site header) instead of replacing them. When OFF, they override the inherited ones.]]></Description>
      <SortOrder>-2</SortOrder>
      <Tab Alias="layout">Layout</Tab>
      <Variations>Nothing</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>false</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>e3c4d5e6-f708-4192-83a4-b5c6d7e8f901</Key>
      <Name>Bottom Component</Name>
      <Alias>bottomComponent</Alias>
      <Definition>bca07c25-6e90-4c68-8f5e-738821c107be</Definition>
      <Type>Umbraco.BlockGrid</Type>
      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Shared content shown BELOW every child page's content. Child pages can override.]]></Description>
      <SortOrder>0</SortOrder>
      <Tab Alias="layout/bottomContent">Bottom Content</Tab>
      <Variations>Culture</Variations>
      <MandatoryMessage></MandatoryMessage>
      <ValidationRegExpMessage></ValidationRegExpMessage>
      <LabelOnTop>true</LabelOnTop>
    </GenericProperty>
    <GenericProperty>
      <Key>dad4e5f6-7182-4394-b5a6-172839405162</Key>
