@using uTPro.Feature.SimpleForm.Helpers
@model uTPro.Feature.SimpleForm.Models.FormFieldViewModel
@{
    var h = new FieldHelper(Model, ViewData);
    var rows = h.Attr("rows", "4");
}

@h.Label()
<textarea id="@h.FieldId"
          name="@h.Name"
          placeholder="@Model.Placeholder"
          @h.RequiredAttr()
          rows="@rows"
          @h.DataMsgAttr()>@Model.DefaultValue</textarea>
@h.Error()
