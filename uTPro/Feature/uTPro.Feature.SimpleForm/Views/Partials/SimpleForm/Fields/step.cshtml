@* Form Step divider — renders a visual step separator *@
@model uTPro.Feature.SimpleForm.Models.FormFieldViewModel
@{
    var title = Model.Attributes?.GetValueOrDefault("title") ?? Model.Label ?? "Next Step";
}

<div class="sf-step">
    <h3 class="sf-step-title">@title</h3>
    <hr class="sf-step-divider" />
</div>
